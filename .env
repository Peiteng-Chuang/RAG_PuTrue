# 環境變數設定
GEMINI_API_KEY=AIzaSyAZPwIKOMIjBCnz3gp5EQdZrjg_XQ4sG3k

POPPLER_PATH=C:\Program Files\poppler-25.12.0\Library\bin

# vLLM（OpenAI 相容 API）— chat 後端
# base_url 必須含 /v1
VLLM_BASE_URL=http://192.168.201.66:8000/v1
# vLLM 預設不驗 API key，但 OpenAI client 需非空字串；服務若有設 key 再改此值
VLLM_API_KEY=EMPTY

# 模型名稱（chat 的 model id 以 vLLM /v1/models 動態清單為準；下列為抓不到時的 fallback）
VLM_MODEL_NAME=qwen3-vl:latest
LLM_MODEL_NAME=qwen3:32b

# （舊）Ollama 設定 — chat 已改用 vLLM；保留供其他腳本／批次參考
